# =============================================================================
# Bedrock QA Validation System - Git Ignore
# =============================================================================

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# CDK config with sensitive data (use config.example.json as template)
cdk/config.json

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.pytest_cache/
.hypothesis/
*.egg-info/
dist/
build/
*.egg

# =============================================================================
# Node.js / Frontend
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build output
frontend/build/

# =============================================================================
# CDK / AWS
# =============================================================================
cdk/cdk.out/
cdk/*.js
cdk/*.d.ts
!cdk/jest.config.js

# =============================================================================
# IDE & Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Kiro
# =============================================================================
.kiro/

# =============================================================================
# Logs & Temp
# =============================================================================
*.log
tmp/
temp/
